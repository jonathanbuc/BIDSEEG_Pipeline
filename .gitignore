# ── PI's original delivery (kept locally as raw-data source, not tracked) ──
HierarchicalPriors_pipeline/

# ── OS / editor cruft ──
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ipynb_checkpoints/

# ── Virtual environments ──
.venv/
venv/
env/

# ── Large / generated data (NOT the committed BIDS inputs) ──
# Raw source EEG (BrainVision .eeg/.vhdr/.vmrk) — too large for git, lives locally.
# NOTE: the small demo behavioral logs in data/sourcedata/logfiles/ and the trait
# CSV ARE tracked so a clean clone can run modules b/c/d end-to-end.
data/sourcedata/raw/
# Pipeline outputs / derivatives are regenerated by the pipeline
data/BIDShierPriors/derivatives/
# Generated BIDSification logs (NOTE: data/sourcedata/logfiles/ is behavioral
# DATA and stays tracked — only the BIDS-root logfiles are generated noise)
data/BIDShierPriors/logfiles/

# ── Misc local artifacts ──
*.log
_env_probe.py
# Stray Windows "/dev/null" path artifact (LFS hooks land here by accident)
dev/
# Generated doc exports only — the .md sources (ARCHITECTURE, learning notes) stay tracked
docs/*.html

# ── AI assistant rules (agent-specific, not tracked) ──
AGENTS.md
CLAUDE.md
.bob/
